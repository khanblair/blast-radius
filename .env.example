# --- DataHub ---
DATAHUB_GMS_URL=http://localhost:8080
DATAHUB_FRONTEND_URL=http://localhost:9002
DATAHUB_GMS_TOKEN=

# --- Postgres warehouse (estate) ---
PG_HOST=localhost
PG_PORT=5433
PG_USER=postgres_user
PG_PASSWORD=postgres_password
PG_DATABASE=warehouse

# --- GitHub (PR-automation bot identity) ---
GITHUB_TOKEN=

# --- LLM layer (provider-configurable; only the key(s) for the provider(s) in use are required) ---
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
DEEPSEEK_API_KEY=
GEMINI_API_KEY=
